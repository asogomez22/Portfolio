---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";

// --- DATOS DEL PROYECTO (Enfoque en Funcionalidad) ---
const featureCategories = [
  {
    title: "Facturación y Presupuestos",
    desc: "Control total sobre el ciclo de ingresos de tu negocio.",
    items: [
      "Ciclo de vida completo de facturas: Borrador, Enviada, Pagada y Vencida.",
      "Creación y envío de presupuestos con conversión a factura en un solo clic tras su aceptación.",
      "Generación y descarga de documentos en PDF, envío directo por correo electrónico y opción de duplicado.",
      "Motor de facturas recurrentes para automatizar cobros periódicos (mensuales o anuales).",
      "Vista pública mediante enlace seguro para que los clientes descarguen sus facturas sin necesidad de registrarse.",
      "Integración de pasarela de pagos para cobros online directos."
    ]
  },
  {
    title: "Gestión Financiera",
    desc: "Control de gastos y previsiones fiscales automáticas.",
    items: [
      "Registro detallado de gastos con categorización fiscal y subida de comprobantes.",
      "Cálculo en tiempo real de impuestos: IVA (Repercutido/Soportado) e IRPF.",
      "Hucha Fiscal: Indicador inteligente que calcula cuánto debes guardar para las declaraciones trimestrales.",
      "Exportación de reportes, listados de facturas y gastos en formatos Excel y CSV."
    ]
  },
  {
    title: "CRM y Recursos Humanos",
    desc: "Gestión de la relación con clientes y el equipo de trabajo.",
    items: [
      "Fichas completas de clientes con historial de facturación y control de deuda acumulada.",
      "Gestión de perfiles de empleados con asignación de roles diferenciados.",
      "Control horario para el registro de entradas y salidas de la jornada laboral.",
      "Geolocalización con registro de coordenadas exactas al momento de fichar y visualización de rutas.",
      "Panel personal para que cada empleado revise su historial de tiempos y ubicaciones."
    ]
  },
  {
    title: "Herramientas y Utilidades",
    desc: "Optimizaciones para el flujo de trabajo diario.",
    items: [
      "Catálogo de productos y servicios para agilizar la creación de facturas y presupuestos.",
      "Buscador global instantáneo para localizar clientes, documentos o artículos en toda la plataforma.",
      "Sistema granular de roles y permisos (Dueño, Gestor, Empleado).",
      "Centro de notificaciones y alertas internas para eventos importantes."
    ]
  },
  {
    title: "Administración del Sistema",
    desc: "Panel de control general para la gestión de la plataforma.",
    items: [
      "Control de acceso inteligente basado en el estado activo de la suscripción.",
      "Panel de administración global con métricas clave del sistema.",
      "Gestión centralizada de cuentas de usuario, incluyendo suspensiones y extensiones de servicio.",
      "Sistema de suplantación segura de identidad (impersonation) para brindar soporte técnico directo.",
      "Creación y gestión de cupones de descuento."
    ]
  }
];
---

<style>
  /* === ESTILOS NATIVOS AVANZADOS === */
  .text-shine {
    background: linear-gradient(
      110deg,
      #f0f7ff 30%,
      #7dd3fc 50%,
      #f0f7ff 70%
    );
    background-size: 200% auto;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shine 4s linear infinite;
  }
  @keyframes shine {
    to { background-position: 200% center; }
  }

  .glow-card {
    position: relative;
  }
  .glow-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.06), transparent 40%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
    z-index: 1;
  }
  .glow-card:hover::before {
    opacity: 1;
  }
</style>

<Layout>
<main class="overflow-x-hidden bg-sky-700 selection:bg-white/20 selection:text-white font-sans">
  
  <section class="relative min-h-[100svh] w-full flex flex-col items-center justify-center py-20 mb-20">
    <Header />

    <div class="absolute inset-0 z-0 opacity-25 bg-[radial-gradient(rgba(255,255,255,0.70)_1px,transparent_1px)] bg-[size:18px_18px] pointer-events-none"></div>

    <div class="absolute bottom-0 left-0 w-full h-[14vh] sm:h-[20vh] z-10 bg-gradient-to-t from-cyan-700 to-transparent"></div>

    <div class="relative z-20 flex flex-col items-center max-w-5xl px-4 mt-16 text-center">
      
      <span class="inline-block py-1 px-3 rounded-full bg-amber-500/20 text-amber-200 border border-amber-500/30 text-sm font-semibold tracking-wide mb-6 uppercase">
        Actualmente en fase de desarrollo
      </span>

      <h1 class="text-6xl sm:text-7xl md:text-9xl font-extrabold leading-[1.08] tracking-tight text-shine pb-2">
        Veltra
      </h1>

      <p class="mt-4 text-2xl md:text-3xl font-bold text-white/80 tracking-wide">
        Gestión total para tu negocio
      </p>

      <p class="mt-6 text-base md:text-lg text-white/70 leading-relaxed max-w-2xl font-light">
        Una aplicación web integral diseñada para autónomos y pequeñas empresas. Actúa como el sistema operativo de tu negocio, centralizando facturación, gastos, clientes y equipo en una interfaz moderna y eficiente.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="#caracteristicas" class="inline-flex items-center rounded-full text-sky-900 bg-white px-8 py-3.5 text-base sm:text-lg font-bold shadow-lg shadow-black/20 transition hover:-translate-y-0.5 hover:bg-sky-50 focus:outline-none focus:ring-2 focus:ring-white/50">
          Descubrir Funcionalidades
        </a>
      </div>
    </div>
  </section>

  <div class="bg-gradient-to-b from-cyan-700 via-cyan-950 to-zinc-950 relative">
    
    <section class="relative z-20 mx-auto max-w-6xl px-4 sm:px-6 md:px-10 -mt-10 sm:-mt-20">
      <div class="rounded-3xl border border-white/20 bg-white/10 p-2 sm:p-4 backdrop-blur-xl shadow-2xl shadow-black/50 transition duration-700 hover:-translate-y-2">
        <div class="relative overflow-hidden rounded-2xl bg-zinc-900 border border-white/10">
          <img 
            src="/1.png" 
            alt="Dashboard General de Veltra" 
            class="w-full h-auto object-cover opacity-90 transition-transform duration-700 hover:scale-[1.01]"
          />
        </div>
      </div>
    </section>

    <section id="caracteristicas" class="relative z-20 mx-auto max-w-6xl px-4 sm:px-6 md:px-10 py-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">Todo lo que necesitas en un solo lugar</h2>
        <p class="text-white/70 text-lg max-w-2xl mx-auto">Centraliza tus operaciones diarias con herramientas pensadas específicamente para ahorrarte tiempo y darte tranquilidad financiera.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featureCategories.map((category) => (
          <div class="glow-card rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-colors hover:bg-white/10">
            <h3 class="text-2xl font-bold text-white mb-2">{category.title}</h3>
            <p class="text-sky-200/80 mb-6 text-sm">{category.desc}</p>
            <ul class="space-y-3">
              {category.items.map((item) => (
                <li class="flex items-start text-white/80 text-sm leading-relaxed">
                  <span class="mr-3 mt-1 block w-1.5 h-1.5 rounded-full bg-sky-400 shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="relative z-20 py-16 text-center">
      <div class="mx-auto max-w-2xl px-4">
        <h2 class="text-3xl font-bold text-white mb-8">Explora el resto del Portfolio</h2>
        <a
          href="/#proyectos"
          class="inline-flex items-center gap-3 rounded-full border border-white/20 bg-white/10 px-8 py-4 text-lg font-bold text-white backdrop-blur-md shadow-lg shadow-black/25 transition hover:bg-white/20 hover:-translate-y-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
          Volver a Proyectos
        </a>
      </div>
    </section>

    <div class="relative z-20 border-t border-white/10">
      <Footer />
    </div>

  </div> 
</main>

<script>
  if (typeof window !== "undefined") {
    const handleOnMouseMove = (e) => {
      const target = e.currentTarget;
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      target.style.setProperty("--mouse-x", `${x}px`);
      target.style.setProperty("--mouse-y", `${y}px`);
    };

    document.querySelectorAll(".glow-card").forEach((card) => {
      card.addEventListener("mousemove", handleOnMouseMove);
    });
  }
</script>
</Layout>