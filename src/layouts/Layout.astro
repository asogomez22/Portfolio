---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Portfolio de Alejandro Sope&ntilde;a. Desarrollador Web Full Stack en Tarragona. Especializado en crear experiencias digitales &uacute;nicas, r&aacute;pidas y accesibles."
    />
    <meta
      name="keywords"
      content="Desarrollador Web, Tarragona, Full Stack, Frontend, Backend, Astro, React, Laravel, Dise&ntilde;o Web, Programador"
    />
    <meta name="author" content="Alejandro Sope&ntilde;a" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://asogom.es/" />
    <meta
      property="og:title"
      content="Portfolio Alejandro Sope&ntilde;a - Desarrollador Web"
    />
    <meta
      property="og:description"
      content="Desarrollador Web Full Stack en Tarragona. Transformo ideas en webs modernas y funcionales."
    />
    <meta property="og:image" content="/portfolio.png" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://asogom.es/" />
    <meta
      property="twitter:title"
      content="Portfolio Alejandro Sope&ntilde;a - Desarrollador Web"
    />
    <meta
      property="twitter:description"
      content="Desarrollador Web Full Stack en Tarragona. Transformo ideas en webs modernas y funcionales."
    />
    <meta property="twitter:image" content="/portfolio.png" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Portfolio Alejandro Sope&ntilde;a</title>
  </head>
  <body>
    <slot />

    <script>
      import Lenis from "lenis";

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 2,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    overflow-x: hidden;
  }

  /* CSS OBLIGATORIO PARA EL SCROLL FLUIDO LENIS */
  html.lenis,
  html.lenis body {
    height: auto;
    width: 100%;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }

  .lenis.lenis-smooth iframe {
    pointer-events: none;
  }
</style>
